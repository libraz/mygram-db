{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for MygramDB metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Dashboard for MygramDB full-text search engine. Monitors server status, query throughput, memory usage, index size, and MySQL binlog replication.",
  "editable": true,
  "id": null,
  "uid": null,
  "title": "MygramDB",
  "tags": ["prometheus", "mygramdb"],
  "timezone": "browser",
  "schemaVersion": 36,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Instance",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "definition": "label_values(mygramdb_server_info, instance)",
        "query": "label_values(mygramdb_server_info, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Uptime",
      "description": "Server uptime since last restart",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "mygramdb_server_uptime_seconds{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 600 },
              { "color": "green", "value": 3600 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Connected Clients",
      "description": "Current number of client connections",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "mygramdb_clients_connected{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Documents",
      "description": "Total number of indexed documents",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "sum(mygramdb_index_documents_total{instance=~\"$instance\"}) by (instance)",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Memory Usage",
      "description": "Application memory as percentage of system memory",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "mygramdb_memory_used_bytes{instance=~\"$instance\", type=\"total\"} / mygramdb_memory_system_total_bytes{instance=~\"$instance\"} * 100",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Replication",
      "description": "MySQL binlog replication status",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "mygramdb_replication_running{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "STOPPED", "color": "red" },
                "1": { "text": "RUNNING", "color": "green" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Memory Health",
      "description": "Memory subsystem health status",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "mygramdb_memory_health_status{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "UNKNOWN", "color": "gray" },
                "1": { "text": "HEALTHY", "color": "green" },
                "2": { "text": "WARNING", "color": "yellow" },
                "3": { "text": "CRITICAL", "color": "red" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Commands / sec",
      "description": "Total command throughput and search commands per second",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(mygramdb_server_commands_total{instance=~\"$instance\"}[1m])",
          "legendFormat": "{{instance}} total"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(mygramdb_command_total{instance=~\"$instance\", command=\"search\"}[1m])",
          "legendFormat": "{{instance}} search"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "pointSize": 5, "showPoints": "auto" }
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Memory Usage",
      "description": "Memory breakdown: index, documents, and process RSS",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "mygramdb_memory_used_bytes{instance=~\"$instance\", type=\"total\"}",
          "legendFormat": "{{instance}} app total"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "mygramdb_memory_used_bytes{instance=~\"$instance\", type=\"index\"}",
          "legendFormat": "{{instance}} index"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "mygramdb_memory_used_bytes{instance=~\"$instance\", type=\"documents\"}",
          "legendFormat": "{{instance}} documents"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "mygramdb_memory_process_rss_bytes{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} RSS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Command Calls / sec by Type",
      "description": "Per-command breakdown (search, count, get, info, etc.)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(mygramdb_command_total{instance=~\"$instance\"}[1m])",
          "legendFormat": "{{instance}} {{command}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Connected Clients",
      "description": "Number of active client connections over time",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "mygramdb_clients_connected{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Replication Events / sec",
      "description": "MySQL binlog replication event rate by operation type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(mygramdb_replication_events_processed{instance=~\"$instance\"}[5m])",
          "legendFormat": "{{instance}} events"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(mygramdb_replication_updates_total{instance=~\"$instance\", status=\"applied\"}[5m])",
          "legendFormat": "{{instance}} updates"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(mygramdb_replication_inserts_total{instance=~\"$instance\", status=\"applied\"}[5m])",
          "legendFormat": "{{instance}} inserts"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "rate(mygramdb_replication_deletes_total{instance=~\"$instance\", status=\"applied\"}[5m])",
          "legendFormat": "{{instance}} deletes"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Index Size",
      "description": "Number of indexed documents and unique terms",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "mygramdb_index_documents_total{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} documents"
        },
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "mygramdb_index_terms_total{instance=~\"$instance\"}",
          "legendFormat": "{{instance}} terms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Replication Status",
      "description": "Replication running state (1=running, 0=stopped)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "mygramdb_replication_running{instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "mappings": [
            { "type": "value", "options": { "0": { "text": "STOPPED" }, "1": { "text": "RUNNING" } } }
          ],
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 30 }
        }
      }
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "System Memory",
      "description": "System-level memory utilization percentage",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": "${DS_PROMETHEUS}",
      "targets": [
        {
          "datasource": "${DS_PROMETHEUS}",
          "expr": "mygramdb_memory_system_usage_ratio{instance=~\"$instance\"} * 100",
          "legendFormat": "{{instance}} usage %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10 }
        }
      }
    }
  ]
}
